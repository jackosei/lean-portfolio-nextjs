# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Neon serverless Postgres connection string.
# Get it from: Neon dashboard → your project → Connection Details → "Pooled connection".
# Example: postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Long random secret used to sign the editor session cookie.
# Generate one with: openssl rand -hex 32
AUTH_SECRET=

# SHA-256 hash of your 6-digit edit PIN (the PIN itself never appears here).
# Generate it with: npm run pin:hash -- 123456
EDIT_PIN_HASH=

# screenshotone.com access key for live preview thumbnails.
# Get one at https://screenshotone.com. Without it, cards show "No preview".
SCREENSHOTONE_ACCESS_KEY=
