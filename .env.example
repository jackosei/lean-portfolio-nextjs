# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Neon serverless Postgres connection string.
# Get it from: Neon dashboard → your project → Connection Details → "Pooled connection".
# Example: postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Long random secret used to sign the editor session cookie.
# Generate one with: openssl rand -hex 32
AUTH_SECRET=

# SHA-256 hash of your 6-digit edit PIN (the PIN itself never appears here).
# Generate it with: npm run pin:hash -- 123456
EDIT_PIN_HASH=

# screenshotone.com access key for live preview thumbnails (optional).
# Falls back to the key that shipped with the original site if left blank.
SCREENSHOTONE_ACCESS_KEY=

# Only needed if you run `npm run db:migrate-supabase` and your old Supabase
# project differs from the defaults baked into the migration script.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
